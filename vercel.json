    },
    {
      "source": "/portfolio",
      "destination": "/index.html"
    },
    {
      "source": "/contact",
      "destination": "/index.html"
    },
    {
      "source": "/about/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/services/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/portfolio/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/contact/(.*)",
      "destination": "/index.html"
    }
  ]
}
